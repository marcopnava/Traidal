# PayPal "Log In with PayPal" credentials
# Get them from https://developer.paypal.com (create an app with "Log In with PayPal" enabled)

# Public (safe to expose in the browser)
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_ENV=sandbox

# Server-side (used by api/paypal/exchange.ts on Vercel)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
